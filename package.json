{
  "name": "morse-root",
  "private": true,
  "scripts": {
    "prepare": "husky",
    "lint:trainer": "npm run lint --prefix trainer",
    "format:trainer": "npm run format --prefix trainer",
    "check:trainer": "npm run check --prefix trainer",
    "test:trainer": "npm run test --prefix trainer",
    "build:firmware": "cd firmware && pio run",
    "lint:firmware": "cd firmware && pio check --skip-packages"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^9.2.1",
    "eslint": "^10.1.0",
    "eslint-plugin-svelte": "^3.16.0",
    "globals": "^17.4.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.2",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte-eslint-parser": "^1.6.0",
    "typescript-eslint": "^8.57.1"
  },
  "lint-staged": {
    "trainer/**/*.{js,ts,svelte}": [
      "prettier --write --config trainer/.prettierrc --ignore-path trainer/.prettierignore",
      "concurrently --raw \"eslint --config trainer/eslint.config.js\" \"vitest run --dir trainer\" \"npm run check --prefix trainer\""
    ],
    "firmware/**/*.{cpp,h,ino}": [
      "sh -c \"cd firmware && pio run && pio check --skip-packages\""
    ]
  }
}
